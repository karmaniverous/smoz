{
  "project": ["src/**", "app/**", "!**/generated/**", "!docs/**"],
  "ignore": [
    "app/config/openapi.ts",
    "app/functions/**/lambda.ts",
    "app/functions/**/openapi.ts",
    "src/serverless/intrinsic.ts",
    "src/cli/local/inline.server/**"
  ],
  "ignoreBinaries": ["plantuml"],
  "ignoreDependencies": ["@types/fs-extra", "fs-extra"],
  "rules": { "exports": "off", "types": "off" }
}
